# Copy to `.env` and fill values as needed.

# ── API keys (use at least one) ─────────────────────────────────────
OPENAI_API_KEY=
VOCAREUM_API_KEY=

# Optional: if using Vocareum proxy
ENERGY_ADVISOR_BASE_URL=https://openai.vocareum.com/v1

# ── Model switching ─────────────────────────────────────────────────
ENERGY_ADVISOR_MODEL_PRESET=fast
ENERGY_ADVISOR_MODEL_FAST=gpt-4o-mini
ENERGY_ADVISOR_MODEL_QUALITY=gpt-4o
# ENERGY_ADVISOR_MODEL=your_custom_model

# ── Service mode / ports (container targets) ───────────────────────
SERVICE_MODE=streamlit
PORT=8501
ENERGY_ADVISOR_BOOTSTRAP_VECTORSTORE=false

# ── Storage ─────────────────────────────────────────────────────────
ENERGY_ADVISOR_DB_PATH=data/energy_data.db
ENERGY_ADVISOR_DOCS_DIR=data/documents
ENERGY_ADVISOR_VECTORSTORE_DIR=data/vectorstore
ENERGY_ADVISOR_MODELS_DIR=data/models
ENERGY_ADVISOR_ANEEL_CACHE_PATH=data/aneel_bandeiras_cache.json
ENERGY_ADVISOR_ANEEL_FETCH_ENABLED=true
ENERGY_ADVISOR_ANEEL_ALLOW_INSECURE_SSL=false

# ── Forecasting / ML (optional) ─────────────────────────────────────
# baseline | ml | auto
ENERGY_ADVISOR_USAGE_FORECAST_MODE=auto
# Train models at container startup (adds time to first boot)
ENERGY_ADVISOR_TRAIN_ML_ON_START=false

# ── Agent loop limits ───────────────────────────────────────────────
# One ReAct iteration = assistant step + tools step. The cap converts a
# runaway tool loop into an honest "couldn't finish" answer instead of an
# unbounded LLM bill.
ENERGY_ADVISOR_MAX_AGENT_ITERATIONS=10
ENERGY_ADVISOR_LLM_TIMEOUT_S=60
ENERGY_ADVISOR_LLM_MAX_RETRIES=2

# ── Cost accounting ─────────────────────────────────────────────────
# Optional override of the USD-per-1k-token pricing table, JSON:
# {"model-name": [input_per_1k, output_per_1k]}
# ENERGY_ADVISOR_MODEL_PRICING_JSON={"gpt-4o-mini": [0.00015, 0.0006]}

# ── Logging ─────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── LangSmith (optional) ────────────────────────────────────────────
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=ecohome-energy-advisor
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── Topicality (AgentContract scope) ────────────────────────────────
# audit: log out-of-scope questions (default) | block: friendly redirect, no LLM call
ENERGY_ADVISOR_SCOPE_MODE=audit
