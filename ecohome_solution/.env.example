# Copy to `.env` and fill values as needed.

# API keys (use at least one)
OPENAI_API_KEY=
VOCAREUM_API_KEY=

# Optional: if using Vocareum proxy
ENERGY_ADVISOR_BASE_URL=https://openai.vocareum.com/v1

# Model switching
ENERGY_ADVISOR_MODEL_PRESET=fast
ENERGY_ADVISOR_MODEL_FAST=gpt-5-mini
ENERGY_ADVISOR_MODEL_QUALITY=gpt-5.2
# ENERGY_ADVISOR_MODEL=your_custom_model

# Logging
LOG_LEVEL=INFO

# LangSmith (optional)
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=ecohome-energy-advisor
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

